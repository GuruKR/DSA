
class Solution {
    public int maxProduct(int[] nums) {
        if (nums == null || nums.length == 0)
            return 0;

        int maxProd = nums[0]; //maximum product so far
        int minProd = nums[0]; //minimum product so far
        int result = nums[0]; //final result

        for (int i = 1; i < nums.length; i++) {
            int n = nums[i];

            if (n < 0) {
                // swap the min and max product if its negative
                int temp = maxProd;
                maxProd = minProd;
                minProd = temp;
            }
            maxProd = Math.max(n, maxProd * n);
            minProd = Math.min(n, minProd * n);

            result = Math.max(result, maxProd);

        }
        return result;

    }
}
